# REST API base URL (telemetry-processing-api-service).
# Leave unset when using Docker: UI is served from the same host and nginx proxies /api and /ws to the backend.
# For local dev (Vite on 5173, API on 8081), set:
# VITE_API_BASE_URL=http://localhost:8081

# WebSocket base URL for live telemetry. Leave unset in Docker (same-origin). For local dev:
# VITE_WS_URL=http://localhost:8081
