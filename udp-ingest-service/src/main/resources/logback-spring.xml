<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Log directory: default "logs"; with profile dev use logs-dev/<service> (set in application-dev.yml) -->
    <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="logs"/>
    <springProperty scope="context" name="SERVICE_NAME" source="spring.application.name" defaultValue="app"/>
    <!-- Each run gets a new log file (set in main() before Spring); previous run's file stays as archived. -->
    <property name="STARTUP_TS" value="${log.startup.timestamp:-run}"/>

    <!-- Pattern with traceId for correlation (MDC set per UDP packet in MethodPacketHandler) -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{traceId:-}] [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- Console appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Application log file: new file per run (STARTUP_TS), rotation by day, retention 5 days -->
    <appender name="FILE_APPLICATION" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${SERVICE_NAME}-application-${STARTUP_TS}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${SERVICE_NAME}-application-${STARTUP_TS}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>5</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Inbound UDP: new file per run -->
    <appender name="FILE_INBOUND_UDP" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${SERVICE_NAME}-inbound-udp-${STARTUP_TS}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${SERVICE_NAME}-inbound-udp-${STARTUP_TS}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>5</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    <logger name="inbound-udp" level="DEBUG" additivity="false">
        <appender-ref ref="FILE_INBOUND_UDP"/>
    </logger>

    <!-- Outbound events (Kafka publish): new file per run -->
    <appender name="FILE_OUTBOUND_EVENTS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${SERVICE_NAME}-outbound-events-${STARTUP_TS}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${SERVICE_NAME}-outbound-events-${STARTUP_TS}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>5</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    <logger name="outbound-events" level="DEBUG" additivity="false">
        <appender-ref ref="FILE_OUTBOUND_EVENTS"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE_APPLICATION"/>
    </root>
</configuration>
