<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Log directory: default "logs"; with profile dev use logs-dev/<service> (set in application-dev.yml) -->
    <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="logs"/>
    <springProperty scope="context" name="SERVICE_NAME" source="spring.application.name" defaultValue="app"/>
    <!-- Each run gets a new log file (set in main() before Spring); previous run's file stays as archived. -->
    <property name="STARTUP_TS" value="${log.startup.timestamp:-run}"/>

    <!-- Pattern with traceId for correlation across all log files -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{traceId:-}] [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- Console appender (unchanged behaviour) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Application log file: new file per run (STARTUP_TS), rotation by day, retention 5 days -->
    <appender name="FILE_APPLICATION" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${SERVICE_NAME}-application-${STARTUP_TS}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${SERVICE_NAME}-application-${STARTUP_TS}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>5</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- DB log: Hibernate SQL only. New file per run, same pattern for traceId. -->
    <appender name="FILE_DB" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${SERVICE_NAME}-db-${STARTUP_TS}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${SERVICE_NAME}-db-${STARTUP_TS}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>5</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Inbound events (Kafka consume): new file per run -->
    <appender name="FILE_INBOUND_EVENTS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${SERVICE_NAME}-inbound-events-${STARTUP_TS}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${SERVICE_NAME}-inbound-events-${STARTUP_TS}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>5</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    <logger name="inbound-events" level="DEBUG" additivity="false">
        <appender-ref ref="FILE_INBOUND_EVENTS"/>
    </logger>

    <!-- Hibernate SQL logger: only to db file, not to application (additivity=false) -->
    <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
        <appender-ref ref="FILE_DB"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE_APPLICATION"/>
    </root>
</configuration>
